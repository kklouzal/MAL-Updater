# Optional overrides
MAL_UPDATER_CONFIG_DIR=./config
MAL_UPDATER_SETTINGS_PATH=./config/settings.toml
MAL_UPDATER_SECRETS_DIR=./secrets
MAL_UPDATER_DATA_DIR=./data
MAL_UPDATER_STATE_DIR=./state
MAL_UPDATER_CACHE_DIR=./cache
MAL_UPDATER_DB_PATH=./data/mal_updater.sqlite3
MAL_UPDATER_CRUNCHYROLL_ADAPTER=./rust/crunchyroll_adapter/target/debug/crunchyroll-adapter
MAL_UPDATER_COMPLETION_THRESHOLD=0.90
MAL_UPDATER_CONTRACT_VERSION=1.0
MAL_UPDATER_MAL_BASE_URL=https://api.myanimelist.net/v2
