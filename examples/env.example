# Example environment overrides
# Export only what you need.

MAL_UPDATER_SETTINGS_PATH=./config/settings.toml
MAL_UPDATER_CONFIG_DIR=./config
MAL_UPDATER_SECRETS_DIR=./secrets
MAL_UPDATER_DATA_DIR=./data
MAL_UPDATER_STATE_DIR=./state
MAL_UPDATER_CACHE_DIR=./cache
MAL_UPDATER_DB_PATH=./data/mal_updater.sqlite3

MAL_UPDATER_MAL_CLIENT_ID_FILE=./secrets/mal_client_id.txt
MAL_UPDATER_MAL_CLIENT_SECRET_FILE=./secrets/mal_client_secret.txt
MAL_UPDATER_MAL_ACCESS_TOKEN_FILE=./secrets/mal_access_token.txt
MAL_UPDATER_MAL_REFRESH_TOKEN_FILE=./secrets/mal_refresh_token.txt

MAL_UPDATER_CRUNCHYROLL_USERNAME_FILE=./secrets/crunchyroll_username.txt
MAL_UPDATER_CRUNCHYROLL_PASSWORD_FILE=./secrets/crunchyroll_password.txt
MAL_UPDATER_CRUNCHYROLL_LOCALE=en-US
