MAL_UPDATER_MAL_TOKEN_URL=https://myanimelist.net/v1/oauth2/token
MAL_UPDATER_MAL_REDIRECT_HOST=127.0.0.1
MAL_UPDATER_MAL_REDIRECT_PORT=8765
