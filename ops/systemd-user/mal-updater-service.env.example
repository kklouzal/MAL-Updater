# Optional EnvironmentFile for mal-updater.service
# Copy to ~/.config/mal-updater-service.env and adjust as needed.

# Service loop cadence defaults (seconds)
# MAL_UPDATER_SERVICE_SYNC_EVERY_SECONDS=21600
# MAL_UPDATER_SERVICE_HEALTH_EVERY_SECONDS=43200
# MAL_UPDATER_SERVICE_MAL_REFRESH_EVERY_SECONDS=21600
# MAL_UPDATER_SERVICE_LOOP_SLEEP_SECONDS=30

# Request-budget thresholds
# MAL_UPDATER_SERVICE_CRUNCHYROLL_HOURLY_LIMIT=180
# MAL_UPDATER_SERVICE_MAL_HOURLY_LIMIT=120
# MAL_UPDATER_SERVICE_WARN_RATIO=0.8
# MAL_UPDATER_SERVICE_CRITICAL_RATIO=0.95
