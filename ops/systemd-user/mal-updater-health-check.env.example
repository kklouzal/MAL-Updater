# Optional systemd EnvironmentFile for mal-updater-health-check.service
# Copy to ~/.config/mal-updater-health-check.env and adjust as needed.
#
# Keep this focused on non-interactive automation-safe maintenance only.
# The wrapper will still refuse commands that are not marked automation_safe.

# Warn when the newest completed ingest is older than this many hours.
MAL_UPDATER_HEALTH_STALE_HOURS=72

# Return non-zero from the service when warnings remain after the final health-check pass.
# 0 = keep the service green while still logging warnings
# 1 = exit 2 when warnings remain
MAL_UPDATER_HEALTH_STRICT=0

# Optional safe self-remediation.
# 0 = observe only
# 1 = execute the first allowed automation-safe maintenance command, then re-run health-check
MAL_UPDATER_HEALTH_AUTO_RUN_RECOMMENDED=0

# Restrict which maintenance reason codes the wrapper may auto-run.
# Recommended conservative default when enabling self-remediation:
# refresh_full_snapshot
#
# Broader option if you also want incremental refresh repairs:
# refresh_ingested_snapshot,refresh_full_snapshot
MAL_UPDATER_HEALTH_AUTO_RUN_REASON_CODES=refresh_full_snapshot
