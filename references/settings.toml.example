# Non-secret runtime configuration.
# Copy to .MAL-Updater/config/settings.toml (or point MAL_UPDATER_SETTINGS_PATH at another file).
# Paths may be absolute or relative to this settings file.

completion_threshold = 0.95
credits_skip_window_seconds = 120
contract_version = "1.0"

[paths]
config_dir = "./"
secrets_dir = "../secrets"
data_dir = "../data"
state_dir = "../state"
cache_dir = "../cache"
db_path = "../data/mal_updater.sqlite3"

[mal]
base_url = "https://api.myanimelist.net/v2"
auth_url = "https://myanimelist.net/v1/oauth2/authorize"
token_url = "https://myanimelist.net/v1/oauth2/token"
bind_host = "0.0.0.0"
redirect_host = "127.0.0.1"
redirect_port = 8765
request_spacing_seconds = 1.0
request_spacing_jitter_seconds = 0.2

[crunchyroll]
locale = "en-US"
request_spacing_seconds = 22.5
request_spacing_jitter_seconds = 7.5

[service]
sync_every_seconds = 21600
full_refresh_every_seconds = 86400
health_every_seconds = 43200
mal_refresh_every_seconds = 21600
loop_sleep_seconds = 30
crunchyroll_hourly_limit = 180  # legacy Crunchyroll-specific override
source_provider_hourly_limit = 180
source_provider_warn_backoff_floor_seconds = 0
source_provider_critical_backoff_floor_seconds = 0
source_provider_auth_failure_backoff_floor_seconds = 0
mal_hourly_limit = 120
warn_ratio = 0.8
critical_ratio = 0.95

[service.provider_hourly_limits]
hidive = 72  # built-in default shown explicitly here; override only when this host needs a different HIDIVE budget

[service.task_hourly_limits]
sync_apply = 48  # built-in default shown explicitly here; override only when this host needs a different aggregate-apply MAL budget

[service.task_projected_request_counts]
sync_apply = 8  # built-in default shown explicitly here; override only when this host needs a different aggregate-apply request-cost estimate
sync_fetch_crunchyroll = 12  # optional incremental-ish fallback when you want a task-wide Crunchyroll cost estimate outside mode-specific defaults

[service.task_projected_request_counts_by_mode.sync_fetch_crunchyroll]
incremental = 4  # built-in default shown explicitly here; fresh installs now seed the ordinary Crunchyroll fetch path with a conservative non-zero cost
full_refresh = 55  # built-in default shown explicitly here; cold-start Crunchyroll full refreshes are materially heavier than incremental fetches

[service.task_projected_request_counts_by_mode.sync_fetch_hidive]
incremental = 4  # built-in default shown explicitly here; fresh installs now seed the ordinary HIDIVE fetch path with a conservative non-zero cost
full_refresh = 71  # built-in default shown explicitly here; use mode-specific task defaults when a lane's full refresh is much more expensive than incremental fetches

[service.provider_projected_request_history_windows]
crunchyroll = 7  # built-in default shown explicitly here; override only when this host needs a different learned-history depth
hidive = 9  # built-in default shown explicitly here

[service.task_projected_request_history_windows]
sync_fetch_crunchyroll = 7  # optional lane-specific override; task settings win over provider defaults when both exist
sync_apply = 3  # built-in default shown explicitly here

[service.provider_projected_request_percentiles]
crunchyroll = 0.9  # built-in default shown explicitly here; override only when this host needs a different provider-wide conservative projection

[service.task_projected_request_percentiles]
sync_fetch_crunchyroll = 0.9  # optional conservative learned projection; when unset the daemon falls back to provider defaults, then smoothed/auto-bursty behavior

[service.provider_warn_backoff_floor_seconds]
crunchyroll = 900  # built-in default shown explicitly here
hidive = 300  # built-in default shown explicitly here

[service.provider_critical_backoff_floor_seconds]
crunchyroll = 1800  # built-in default shown explicitly here
hidive = 1200  # built-in default shown explicitly here

[service.task_warn_backoff_floor_seconds]
sync_apply = 900  # built-in default shown explicitly here

[service.task_critical_backoff_floor_seconds]
sync_apply = 1800  # built-in default shown explicitly here

[service.provider_auth_failure_backoff_floor_seconds]
crunchyroll = 7200  # built-in default shown explicitly here
hidive = 3600  # built-in default shown explicitly here

[service.task_auth_failure_backoff_floor_seconds]
sync_apply = 2400  # built-in default shown explicitly here

[secret_files]
mal_client_id = "mal_client_id.txt"
mal_client_secret = "mal_client_secret.txt"
mal_access_token = "mal_access_token.txt"
mal_refresh_token = "mal_refresh_token.txt"
crunchyroll_username = "crunchyroll_username.txt"
crunchyroll_password = "crunchyroll_password.txt"
