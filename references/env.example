# Example environment overrides
# Export only what you need.
# Defaults point at the workspace runtime root: ./.MAL-Updater/

MAL_UPDATER_WORKSPACE_DIR=.
MAL_UPDATER_RUNTIME_ROOT=./.MAL-Updater
MAL_UPDATER_SETTINGS_PATH=./.MAL-Updater/config/settings.toml
MAL_UPDATER_CONFIG_DIR=./.MAL-Updater/config
MAL_UPDATER_SECRETS_DIR=./.MAL-Updater/secrets
MAL_UPDATER_DATA_DIR=./.MAL-Updater/data
MAL_UPDATER_STATE_DIR=./.MAL-Updater/state
MAL_UPDATER_CACHE_DIR=./.MAL-Updater/cache
MAL_UPDATER_DB_PATH=./.MAL-Updater/data/mal_updater.sqlite3

MAL_UPDATER_MAL_CLIENT_ID_FILE=./.MAL-Updater/secrets/mal_client_id.txt
MAL_UPDATER_MAL_CLIENT_SECRET_FILE=./.MAL-Updater/secrets/mal_client_secret.txt
MAL_UPDATER_MAL_ACCESS_TOKEN_FILE=./.MAL-Updater/secrets/mal_access_token.txt
MAL_UPDATER_MAL_REFRESH_TOKEN_FILE=./.MAL-Updater/secrets/mal_refresh_token.txt

MAL_UPDATER_CRUNCHYROLL_USERNAME_FILE=./.MAL-Updater/secrets/crunchyroll_username.txt
MAL_UPDATER_CRUNCHYROLL_PASSWORD_FILE=./.MAL-Updater/secrets/crunchyroll_password.txt
MAL_UPDATER_CRUNCHYROLL_LOCALE=en-US

MAL_UPDATER_OPENCLAW_RECOMMENDATIONS_WEBHOOK_ENABLED=true
MAL_UPDATER_OPENCLAW_RECOMMENDATIONS_WEBHOOK_URL=http://127.0.0.1:18789/hooks/agent
MAL_UPDATER_OPENCLAW_RECOMMENDATIONS_WEBHOOK_CHANNEL=discord
MAL_UPDATER_OPENCLAW_RECOMMENDATIONS_WEBHOOK_TO=channel:1487239758487748761
MAL_UPDATER_OPENCLAW_RECOMMENDATIONS_WEBHOOK_DELIVERY_MODE=fresh
MAL_UPDATER_SERVICE_RECOMMENDATIONS_WEBHOOK_PUSH_EVERY_SECONDS=21600
MAL_UPDATER_OPENCLAW_HOOK_TOKEN_FILE=./.MAL-Updater/secrets/openclaw_hook_token.txt
